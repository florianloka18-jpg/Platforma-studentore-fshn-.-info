rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Global Deny
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (getUserData().role == 'admin' ||
          (request.auth.token.email == "florianloka3@gmail.com" && request.auth.token.email_verified == true));
    }

    function isTeacher() {
      return isAuthenticated() && getUserData().role == 'TEACHER';
    }

    function ownsClass(classId) {
      return isAuthenticated() && get(/databases/$(database)/documents/classes/$(classId)).data.admin_id == request.auth.uid;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin() || isTeacher();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher() || isAdmin();
      allow update, delete: if isAdmin() || (isTeacher() && resource.data.admin_id == request.auth.uid);
    }

    match /class_members/{memberId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if isAdmin() || isTeacher();
    }

    match /messages/{messageId} {
      allow read: if isAuthenticated() && (
        resource.data.sender_id == request.auth.uid || 
        resource.data.receiver_id == request.auth.uid || 
        resource.data.chat_type in ['CLASS', 'SCHOOL']
      );
      allow create: if isAuthenticated() && request.resource.data.sender_id == request.auth.uid;
    }

    match /notifications/{notificationId} {
      allow read, update, delete: if isOwner(resource.data.user_id);
      allow create: if isAuthenticated();
    }

    match /schedules/{scheduleId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isTeacher() && ownsClass(request.resource.data.class_id));
    }

    match /personal_notes/{noteId} {
      allow read, write: if isOwner(resource.data.user_id || (request != null && request.resource != null && request.resource.data.user_id));
    }
    
    match /library_books/{bookId} {
      allow read: if isAuthenticated();
      allow create: if (isTeacher() || isAdmin());
      allow update, delete: if isAdmin() || (isTeacher() && resource.data.uploader_id == request.auth.uid);
    }

    match /performance_logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher() || isAdmin();
      allow update, delete: if isAdmin() || (isTeacher() && resource.data.teacher_id == request.auth.uid);
      
      match /likes/{userId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId);
      }
      match /comments/{commentId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
        allow delete: if isAdmin() || isOwner(resource.data.user_id);
      }
    }

    match /assignments/{assignmentId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher() || isAdmin();
      allow update, delete: if isAdmin() || (isTeacher() && resource.data.teacher_id == request.auth.uid);
    }

    match /tests/{testId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher() || isAdmin();
      allow update, delete: if isAdmin() || (isTeacher() && resource.data.teacher_id == request.auth.uid);
    }

    match /attendance/{attendanceId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher() || isAdmin();
      allow update, delete: if isAdmin() || (isTeacher() && resource.data.teacher_id == request.auth.uid);
    }

    match /student_activities/{activityId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update, delete: if isAdmin() || isOwner(resource.data.user_id);
    }

    match /academic_performance/{userId} {
      allow read: if isOwner(userId) || isTeacher() || isAdmin();
      allow write: if isAdmin() || isTeacher();
    }

    match /academic_logs/{logId} {
      allow read: if isAuthenticated();
      allow create: if isTeacher() || isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}
