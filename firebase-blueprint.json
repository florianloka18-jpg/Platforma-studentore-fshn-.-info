{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "surname": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["STUDENT", "TEACHER"] },
        "program": { "type": "string" },
        "year": { "type": "string" },
        "group_name": { "type": "string" },
        "study_type": { "type": "string" },
        "phone": { "type": "string" },
        "is_confirmed": { "type": "number" },
        "profile_photo": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "email", "role"]
    },
    "Class": {
      "title": "Class",
      "description": "Classroom information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "code": { "type": "string" },
        "department": { "type": "string" },
        "year": { "type": "string" },
        "group_name": { "type": "string" },
        "study_type": { "type": "string" },
        "admin_id": { "type": "string" }
      },
      "required": ["id", "name", "code"]
    },
    "ClassMember": {
      "title": "ClassMember",
      "description": "Mapping of users to classes",
      "type": "object",
      "properties": {
        "class_id": { "type": "string" },
        "user_id": { "type": "string" },
        "status": { "type": "string", "enum": ["PENDING", "CONFIRMED", "REFUSED"] },
        "joined_at": { "type": "string", "format": "date-time" }
      },
      "required": ["class_id", "user_id", "status"]
    },
    "Schedule": {
      "title": "Schedule",
      "description": "Class schedule entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "class_id": { "type": "string" },
        "teacher_id": { "type": "string" },
        "subject": { "type": "string" },
        "day": { "type": "string" },
        "start_time": { "type": "string" },
        "end_time": { "type": "string" },
        "room": { "type": "string" }
      },
      "required": ["id", "class_id", "teacher_id", "subject", "day"]
    },
    "Message": {
      "title": "Message",
      "description": "Chat message",
      "type": "object",
      "properties": {
        "sender_id": { "type": "string" },
        "receiver_id": { "type": "string" },
        "class_id": { "type": "string" },
        "chat_type": { "type": "string", "enum": ["PRIVATE", "CLASS", "SCHOOL"] },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["sender_id", "content", "chat_type"]
    },
    "Notification": {
      "title": "Notification",
      "description": "User notification",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string" },
        "is_read": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "title", "content"]
    },
    "PersonalNote": {
      "title": "PersonalNote",
      "description": "Student's personal note",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "color": { "type": "string" },
        "is_pinned": { "type": "boolean" },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "content"]
    },
    "Book": {
      "title": "Book",
      "description": "Digital library book",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "author": { "type": "string" },
        "file_path": { "type": "string" },
        "external_link": { "type": "string" },
        "uploader_id": { "type": "string" },
        "class_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "uploader_id", "class_id"]
    },
    "PerformanceLog": {
      "title": "PerformanceLog",
      "description": "Student activity/performance log entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "type": { "type": "string", "enum": ["TEST", "ASSIGNMENT", "ATTENDANCE", "LECTURE"] },
        "score": { "type": "number" },
        "max_score": { "type": "number" },
        "comment": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "type", "timestamp"]
    },
    "ActivityLike": {
      "title": "ActivityLike",
      "description": "User like on an activity log",
      "type": "object",
      "properties": {
        "activity_id": { "type": "string" },
        "user_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["activity_id", "user_id"]
    },
    "ActivityComment": {
      "title": "ActivityComment",
      "description": "Comment on an activity log",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "activity_id": { "type": "string" },
        "user_id": { "type": "string" },
        "user_name": { "type": "string" },
        "content": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "activity_id", "user_id", "content"]
    },
    "ActivityFavorite": {
      "title": "ActivityFavorite",
      "description": "Activity marked as favorite by a user",
      "type": "object",
      "properties": {
        "activity_id": { "type": "string" },
        "user_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["activity_id", "user_id"]
    },
    "CommentLike": {
      "title": "CommentLike",
      "description": "User like on a comment",
      "type": "object",
      "properties": {
        "comment_id": { "type": "string" },
        "user_id": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["comment_id", "user_id"]
    },
    "Assignment": {
      "title": "Assignment",
      "description": "Educational assignment",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "teacher_id": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "program": { "type": "string" },
        "year": { "type": "string" },
        "deadline": { "type": "string", "format": "date-time" },
        "created_at": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["DRAFT", "PUBLISHED", "ARCHIVED"] }
      },
      "required": ["title", "teacher_id", "status"]
    },
    "Test": {
      "title": "Test",
      "description": "Student examination",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "teacher_id": { "type": "string" },
        "title": { "type": "string" },
        "program": { "type": "string" },
        "year": { "type": "string" },
        "duration": { "type": "number" },
        "questions": { "type": "array" },
        "created_at": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["DRAFT", "ACTIVE", "COMPLETED"] }
      },
      "required": ["title", "teacher_id", "status"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Student attendance record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "user_id": { "type": "string" },
        "class_id": { "type": "string" },
        "status": { "type": "string", "enum": ["PRESENT", "ABSENT", "LATE"] },
        "group_name": { "type": "string" },
        "program": { "type": "string" },
        "year": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["user_id", "status", "timestamp"]
    },
    "StudentActivity": {
      "title": "StudentActivity",
      "description": "Student posted activity/event/announcement",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "user_name": { "type": "string" },
        "title": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["EVENT", "DONATION", "POLL"] },
        "duration": { "type": "string", "enum": ["HOUR", "DAY", "WEEK", "MONTH"] },
        "created_at": { "type": "string", "format": "date-time" },
        "expires_at": { "type": "string", "format": "date-time" },
        "link": { "type": "string", "format": "uri" }
      },
      "required": ["user_id", "title", "content", "type", "duration", "created_at", "expires_at"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/classes/{classId}": {
      "schema": "Class",
      "description": "Classrooms"
    },
    "/class_members/{memberId}": {
      "schema": "ClassMember",
      "description": "Class membership records"
    },
    "/schedules/{scheduleId}": {
      "schema": "Schedule",
      "description": "Class schedules"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat messages"
    },
    "/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "User notifications"
    },
    "/personal_notes/{noteId}": {
      "schema": "PersonalNote",
      "description": "Personal student notes"
    },
    "/library_books/{bookId}": {
      "schema": "Book",
      "description": "Digital library materials"
    },
    "/performance_logs/{logId}": {
      "schema": "PerformanceLog",
      "description": "Activity performance logs"
    },
    "/performance_logs/{logId}/likes/{likeId}": {
      "schema": "ActivityLike",
      "description": "Likes on activities"
    },
    "/performance_logs/{logId}/comments/{commentId}": {
      "schema": "ActivityComment",
      "description": "Comments on activities"
    },
    "/performance_logs/{logId}/comments/{commentId}/likes/{likeId}": {
      "schema": "CommentLike",
      "description": "Likes on comments"
    },
    "/performance_logs/{logId}/favorites/{userId}": {
      "schema": "ActivityFavorite",
      "description": "Users who favorited this activity"
    },
    "/assignments/{assignmentId}": {
      "schema": "Assignment",
      "description": "Course assignments"
    },
    "/tests/{testId}": {
      "schema": "Test",
      "description": "Course tests"
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Attendance records"
    },
    "/student_activities/{activityId}": {
      "schema": "StudentActivity",
      "description": "Student posted activities"
    }
  }
}
